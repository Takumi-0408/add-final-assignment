rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /favorites/{favoriteId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;

        // create: name が文字列・1〜50文字・必須フィールドが揃っていること
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 50
          && request.resource.data.keys().hasAll(['name', 'origin', 'destination', 'polyline', 'distanceMeters', 'durationSeconds']);

        // update: name の長さのみ変更可。createdAt・polyline などの重要フィールドは不変
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 50
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.polyline == resource.data.polyline;
      }

      match /walkLogs/{walkLogId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // routesCache はクライアントから直接アクセス不可（Cloud Functions のみ）
    match /routesCache/{routeHash} {
      allow read, write: if false;
    }
  }
}
